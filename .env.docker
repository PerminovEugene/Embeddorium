# ============================================================================
# docker-compose config. Services reach each other by compose service name
# (postgres, qdrant, rabbitmq). For host/local runs, see .env.
#
# NOTE: the chat Agent (laws-generate) is NOT run inside compose, so the
# "Agent / Chat LLM" vars (LLM_PROVIDER, OPENAI_*, OLLAMA_BASE_URL, OLLAMA_MODEL)
# live in .env, not here. This file only configures the pipeline workers.
# ============================================================================

# ── PostgreSQL ──
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=embeddorium_user
POSTGRES_PASSWORD=embeddorium_pass
POSTGRES_DB=embeddorium_db

# ── Qdrant ──
QDRANT_URL=http://qdrant:6333

# ── RabbitMQ ──
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=embeddorium_user2
RABBITMQ_PASSWORD=embeddorium_pass2
RABBITMQ_VHOST=/

# ============================================================================
# Embeddings — chunk-embedding pipeline (worker-embed-chunks).
# ============================================================================
# There is no EMBED_PROVIDER/embedding-model setting: providers (mock, ollama,
# openai) are created in the UI and snapshotted per pipeline run, and
# worker-embed-chunks embeds with exactly the provider its run recorded.
#
# The vars below only pre-fill the "new provider" form served by the `server`
# service. Because that form is filled in from a browser but *dialled* from
# inside the worker container, the default must be container-reachable — NOT
# http://localhost (each container has its own loopback). Use:
#   - Ollama on the host (Mac/Windows Docker Desktop): http://host.docker.internal
#   - Ollama as the `ollama` compose service (profile "ollama"): http://ollama
OLLAMA_URL=http://host.docker.internal
OLLAMA_PORT=11434

# ============================================================================
# HTTP ports. To change one for the compose stack, set it in `.env` — compose
# interpolates ${SERVER_PORT}/${UI_PORT} in docker-compose.yml from there, not
# from this file (same as POSTGRES_PORT / RABBITMQ_PORT). docker-compose.yml
# then re-injects the interpolated UI_PORT onto the `server` and `ui` services'
# `environment:`, which takes precedence over the values below; these are the
# defaults for a container run without that wiring, and documentation.
# ============================================================================
# Port the FastAPI server listens on (and is published on).
SERVER_PORT=8000
# Port the vite dev server listens on (and is published on). The server also
# derives its dev CORS allowlist from it.
UI_PORT=5173

# ============================================================================
# MCP server (backend/mcp/) — exposes the RAG lifecycle as agent tools. It is a
# thin HTTP client of the `server` service; it talks to nothing else. These are
# also set on the `mcp` service's `environment:` in docker-compose.yml (which
# takes precedence); kept here for documentation.
# ============================================================================
# SERVER_URL must be reachable from INSIDE the mcp container — the FastAPI
# server is the `server` compose service, so use its service name, not localhost.
# Its port must match SERVER_PORT above (docker-compose.yml derives the `mcp`
# service's copy from ${SERVER_PORT}).
SERVER_URL=http://server:8000
# Port the MCP server listens on (streamable-HTTP, bound to 0.0.0.0). Agents in
# other containers connect at http://mcp:8080/mcp.
MCP_PORT=8080
