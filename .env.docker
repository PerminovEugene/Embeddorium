# ============================================================================
# docker-compose config. Services reach each other by compose service name
# (postgres, qdrant, rabbitmq). For host/local runs, see .env.
#
# NOTE: the chat Agent (laws-generate) is NOT run inside compose, so the
# "Agent / Chat LLM" vars (LLM_PROVIDER, OPENAI_*, OLLAMA_BASE_URL, OLLAMA_MODEL)
# live in .env, not here. This file only configures the pipeline workers.
# ============================================================================

# ── PostgreSQL ──
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=embeddorium_user
POSTGRES_PASSWORD=embeddorium_pass
POSTGRES_DB=embeddorium_db

# ── Qdrant ──
QDRANT_URL=http://qdrant:6333

# ── RabbitMQ ──
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=embeddorium_user2
RABBITMQ_PASSWORD=embeddorium_pass2
RABBITMQ_VHOST=/

# ============================================================================
# Embeddings — chunk-embedding pipeline (worker-embed-chunks).
# ============================================================================
# EMBED_PROVIDER selects how chunk vectors are produced (all remote/API or mock —
# Embeddorium never loads an embedding model in-process):
#   mock   = random vectors, no model load (fast end-to-end pipeline testing).
#   ollama = remote HTTP call to an Ollama server (e.g. qwen3-embedding).
#   openai = remote OpenAI-compatible embeddings API.
EMBED_PROVIDER=ollama

# mock provider: vector dimension.
MOCK_EMBED_DIM=4096

# ollama provider: endpoint + model. OLLAMA_EMBED_BASE_URL must be reachable
# from INSIDE the worker-embed-chunks container — NOT http://localhost:11434
# (each container has its own loopback). Use:
#   - Ollama on the host (Mac/Windows Docker Desktop): http://host.docker.internal:11434
#   - Ollama as the `ollama` compose service (profile "ollama"): http://ollama:11434
OLLAMA_EMBED_BASE_URL=http://host.docker.internal:11434
OLLAMA_EMBED_MODEL=qwen3-embedding
