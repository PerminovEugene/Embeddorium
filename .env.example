# ============================================================================
# Template for `.env` — the HOST/local config (processes run directly on the
# host: migrations, the embeddings tester, the chat agent, the test suite).
#
#   cp .env.example .env
#
# The Docker Compose stack does NOT use this file for its workers — those read
# `.env.docker` (committed, service-name hosts). Compose DOES read this `.env`
# for `${...}` interpolation in docker-compose.yml (Postgres/RabbitMQ
# credentials + ports), so you need it even for a pure-Docker run.
#
# Full reference: docs/configuration.md
# ============================================================================

# HuggingFace token. Optional: only the `huggingface` embedding provider uses
# it, and it no-ops when unset. Leave blank unless you run that provider.
HG_TOKEN=

# ── PostgreSQL ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=laws_user
POSTGRES_PASSWORD=laws_pass
POSTGRES_DB=laws_db

# ── Qdrant ──
QDRANT_URL=http://localhost:6333

# ── RabbitMQ ──
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=laws_user
RABBITMQ_PASSWORD=laws_pass
RABBITMQ_VHOST=/

# ============================================================================
# Embeddings — the chunk-embedding pipeline fallback provider. In normal use you
# create a provider in the UI and it is snapshotted per run; this env var is only
# the fallback when a run carries no provider. See docs/embeddings.md.
# ============================================================================
# EMBED_PROVIDER: mock | ollama | huggingface
#   mock        = random vectors, no model load (fast end-to-end testing).
#   ollama      = remote HTTP call to an Ollama server.
#   huggingface = local SentenceTransformer model (heavy; not in the Compose image).
EMBED_PROVIDER=mock

# mock provider: vector dimension.
MOCK_EMBED_DIM=4096

# ollama provider: its own endpoint + model (separate from the agent's below).
OLLAMA_EMBED_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=qwen3-embedding

# ============================================================================
# Chat agent (optional LangGraph agent). Independent of the embedding settings.
# ============================================================================
# LLM_PROVIDER: ollama | openai
LLM_PROVIDER=ollama
MCP_SERVER_URL=http://localhost:8000/mcp

# openai provider (LLM_PROVIDER=openai):
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ollama provider (LLM_PROVIDER=ollama): its own endpoint + model.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
